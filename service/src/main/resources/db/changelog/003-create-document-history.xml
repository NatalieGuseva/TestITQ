<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="003-1" author="system">
        <comment>Создание таблицы document_history</comment>

        <createTable tableName="document_history">
            <column name="id" type="BIGINT" defaultValueSequenceNext="document_history_seq">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="document_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_history_document"
                             references="documents(id)"/>
            </column>
            <column name="action" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="performed_by" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="performed_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="comment" type="VARCHAR(1000)"/>
        </createTable>

        <rollback>
            <dropTable tableName="document_history"/>
        </rollback>
    </changeSet>

    <changeSet id="003-2" author="system">
        <comment>Индексы для таблицы document_history</comment>

        <!-- Основной индекс — загрузка истории по документу -->
        <createIndex tableName="document_history" indexName="idx_history_document_id">
            <column name="document_id"/>
        </createIndex>

        <!-- Для сортировки истории по времени -->
        <createIndex tableName="document_history" indexName="idx_history_performed_at">
            <column name="performed_at"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="document_history" indexName="idx_history_document_id"/>
            <dropIndex tableName="document_history" indexName="idx_history_performed_at"/>
        </rollback>
    </changeSet>

    <changeSet id="003-3" author="system">
        <comment>Проверочное ограничение на допустимые значения действия</comment>
        <sql>
            ALTER TABLE document_history
                ADD CONSTRAINT chk_history_action
                    CHECK (action IN ('SUBMIT', 'APPROVE'))
        </sql>
        <rollback>
            ALTER TABLE document_history DROP CONSTRAINT chk_history_action
        </rollback>
    </changeSet>

</databaseChangeLog>