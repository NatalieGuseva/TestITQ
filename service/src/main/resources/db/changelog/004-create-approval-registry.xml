<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="004-1" author="system">
        <comment>Создание таблицы approval_registry — реестр утверждённых документов</comment>

        <createTable tableName="approval_registry">
            <column name="id" type="BIGINT" defaultValueSequenceNext="approval_registry_seq">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <!-- unique constraint — гарантирует что документ утверждается ровно один раз -->
            <column name="document_id" type="BIGINT">
                <constraints nullable="false"
                             unique="true"
                             uniqueConstraintName="uq_registry_document_id"
                             foreignKeyName="fk_registry_document"
                             references="documents(id)"/>
            </column>
            <column name="document_number" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="approved_by" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="approved_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <rollback>
            <dropTable tableName="approval_registry"/>
        </rollback>
    </changeSet>

    <changeSet id="004-2" author="system">
        <comment>Индексы для таблицы approval_registry</comment>

        <createIndex tableName="approval_registry" indexName="idx_registry_approved_at">
            <column name="approved_at"/>
        </createIndex>

        <createIndex tableName="approval_registry" indexName="idx_registry_approved_by">
            <column name="approved_by"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="approval_registry" indexName="idx_registry_approved_at"/>
            <dropIndex tableName="approval_registry" indexName="idx_registry_approved_by"/>
        </rollback>
    </changeSet>

</databaseChangeLog>